{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2022",
        "lib": ["ES2022"],
        "outDir": "out",
        "sourceMap": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "types": ["jest"],
        "typeRoots": ["./node_modules/@types"],
        "baseUrl": ".",
        "paths": {
            "vscode": ["./__mocks__/vscode"]
        }
    },
    "include": ["**/*.ts", "../../src/extension/src/**/*.ts"],
    "exclude": ["node_modules"]
}
