@implements IAsyncDisposable
@inject VsCodeBridgeService Bridge

<div class="git-simple-root">
    <NLCommandBar OnToast="ShowToast"
                  OnError="ShowError"
                  OnRefresh="RefreshAll"
                  OnConfirmRequest="HandleNLConfirm" />

    <QuickActions OnToast="ShowToast"
                  OnError="ShowError"
                  OnRefresh="RefreshAll" />

    <div style="flex:1;overflow-y:auto;">
        <!-- Merge Conflict Resolver (only shows when conflicts exist) -->
        <ConflictPanel @ref="_conflictPanel"
                       OnToast="ShowToast"
                       OnError="ShowError"
                       OnRefresh="RefreshAll"
                       OnConfirmRequest="HandleNLConfirm" />

        <!-- Commit Composer -->
        <CommitPanel @ref="_commitPanel"
                     OnToast="ShowToast"
                     OnError="ShowError"
                     OnRefresh="RefreshAll"
                     OnConfirmRequest="HandleBranchConfirm" />

        <!-- Interactive Staging -->
        <StagingPanel @ref="_stagingPanel"
                      OnToast="ShowToast"
                      OnError="ShowError"
                      OnRefresh="RefreshAll"
                      OnConfirmRequest="HandleNLConfirm" />

        <!-- Branch Panel -->
        <BranchPanel @ref="_branchPanel"
                     OnToast="ShowToast"
                     OnError="ShowError"
                     OnConfirmRequest="HandleBranchConfirm"
                     OnInputRequest="HandleInputRequest" />

        <!-- Tag Management -->
        <TagPanel @ref="_tagPanel"
                  OnToast="ShowToast"
                  OnError="ShowError"
                  OnRefresh="RefreshAll"
                  OnInputRequest="HandleInputRequest"
                  OnConfirmRequest="HandleNLConfirm" />

        <!-- Commit History -->
        <CommitHistory @ref="_historyPanel"
                       OnToast="ShowToast"
                       OnError="ShowError"
                       OnRefresh="RefreshAll"
                       OnInputRequest="HandleInputRequest" />
    </div>
</div>

<ConfirmDialog Visible="_confirmVisible"
               Title="@_confirmTitle"
               Message="@_confirmMessage"
               Warning="@_confirmWarning"
               IsDangerous="_confirmDangerous"
               OnConfirmed="ConfirmAction"
               OnCancelled="CancelConfirm" />

<InputDialog Visible="_inputVisible"
             Title="@_inputTitle"
             Placeholder="@_inputPlaceholder"
             OnSubmitted="InputSubmit"
             OnCancelled="InputCancel" />

<Toast @ref="_toast" />

@code {
    private Action? _repoChangedHandler;
    private bool _initialized;

    private BranchPanel? _branchPanel;
    private ConflictPanel? _conflictPanel;
    private CommitPanel? _commitPanel;
    private StagingPanel? _stagingPanel;
    private TagPanel? _tagPanel;
    private CommitHistory? _historyPanel;
    private Toast? _toast;

    // Confirm dialog state
    private bool _confirmVisible;
    private string _confirmTitle = string.Empty;
    private string _confirmMessage = string.Empty;
    private string? _confirmWarning;
    private bool _confirmDangerous;
    private Func<Task>? _confirmAction;

    // Input dialog state
    private bool _inputVisible;
    private string _inputTitle = string.Empty;
    private string _inputPlaceholder = string.Empty;
    private Func<string, Task>? _inputAction;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            await Bridge.InitializeAsync();
            _repoChangedHandler = () => _ = InvokeAsync(RefreshAll);
            Bridge.OnRepoChanged += _repoChangedHandler;
            await RefreshAll();
            StateHasChanged();
        }
    }

    public ValueTask DisposeAsync()
    {
        if (_repoChangedHandler is not null)
            Bridge.OnRepoChanged -= _repoChangedHandler;
        return ValueTask.CompletedTask;
    }

    private void ShowToast(string msg) => _toast?.Show(msg);
    private void ShowError(string msg) => _toast?.Show(msg, true);

    private async Task RefreshAll()
    {
        try
        {
            var tasks = new List<Task>();

            if (_branchPanel is not null)
                tasks.Add(_branchPanel.RefreshAll());
            if (_conflictPanel is not null)
                tasks.Add(_conflictPanel.CheckConflicts());
            if (_commitPanel is not null)
                tasks.Add(_commitPanel.RefreshStagedCount());
            if (_stagingPanel is not null)
                tasks.Add(_stagingPanel.RefreshChanges());
            if (_tagPanel is not null)
                tasks.Add(_tagPanel.LoadTags());
            if (_historyPanel is not null)
                tasks.Add(_historyPanel.LoadHistory());

            await Task.WhenAll(tasks);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowError($"Refresh failed: {ex.Message}");
        }
    }

    private void HandleBranchConfirm((string Title, string Message, Func<Task> OnConfirm) args)
    {
        _confirmTitle = args.Title;
        _confirmMessage = args.Message;
        _confirmWarning = null;
        _confirmDangerous = false;
        _confirmAction = args.OnConfirm;
        _confirmVisible = true;
    }

    private void HandleNLConfirm((string Title, string Message, string? Warning, bool IsDangerous, Func<Task> OnConfirm) args)
    {
        _confirmTitle = args.Title;
        _confirmMessage = args.Message;
        _confirmWarning = args.Warning;
        _confirmDangerous = args.IsDangerous;
        _confirmAction = args.OnConfirm;
        _confirmVisible = true;
    }

    private async Task ConfirmAction()
    {
        _confirmVisible = false;
        if (_confirmAction is not null) await _confirmAction();
    }

    private void CancelConfirm() => _confirmVisible = false;

    private void HandleInputRequest((string Title, string Placeholder, Func<string, Task> OnSubmit) args)
    {
        _inputTitle = args.Title;
        _inputPlaceholder = args.Placeholder;
        _inputAction = args.OnSubmit;
        _inputVisible = true;
    }

    private async Task InputSubmit(string value)
    {
        _inputVisible = false;
        if (_inputAction is not null) await _inputAction(value);
    }

    private void InputCancel() => _inputVisible = false;
}
